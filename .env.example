# Supabase
# Bruges af begge klienter (src/integrations/supabase/client.ts kaster hvis de mangler,
# src/lib/supabase/client.ts fejler blødt). Lovable Cloud injicerer disse automatisk.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Valgfri legacy-alias — lib-klienten falder tilbage til denne hvis PUBLISHABLE mangler:
# VITE_SUPABASE_ANON_KEY=

# Live Data Connectors
VITE_ENABLE_LIVE_DATA=false
# DMI climateData (ægte årsnedbør i miljøbundtet) — gratis nøgle fra open.dmi.dk.
# Server-side only (ingen VITE_-prefix nødvendig i produktion):
DMI_API_KEY=
# DMI Open Data — no key required (open API)
VITE_DMI_BASE_URL=https://opendataapi.dmi.dk
# Miljøportal — no key required (open API)
# Datafordeler — API key required (datafordeler.dk)
VITE_DATAFORDELER_KEY=
# Copernicus Sentinel-2 — token required (dataspace.copernicus.eu); move server-side before production
VITE_COPERNICUS_TOKEN=
